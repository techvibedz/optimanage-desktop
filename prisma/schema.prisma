generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  name             String
  password         String
  role             String     @default("ASSISTANT")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?
  customers        Customer[]
  expenses         Expense[]
  frames           Frame[]
  lensTypes        LensType[]
  orders           Order[]
  payments         Payment[]
  contactLenses    ContactLens[]
}

model Customer {
  id                       String         @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  dateOfBirth              DateTime?
  address                  String?
  insuranceProvider        String?
  insurancePolicyNumber    String?
  insuranceCoverageDetails String?
  notes                    String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  userId                   String
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders                   Order[]
  prescriptions            Prescription[]

  @@index([firstName, lastName])
  @@index([userId])
}

model Prescription {
  id                 String   @id @default(cuid())
  customerId         String
  examinationDate    DateTime
  doctorName         String
  doctorLicense      String
  pupillaryDistance  Float
  readingDistance    Float?
  expirationDate     DateTime
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  hasVLData          Boolean  @default(false)
  hasVPData          Boolean  @default(false)
  vlLeftEyeAxis      Float?
  vlLeftEyeCylinder  Float?
  vlLeftEyePrism     Float?
  vlLeftEyeSphere    Float?
  vlRightEyeAxis     Float?
  vlRightEyeCylinder Float?
  vlRightEyePrism    Float?
  vlRightEyeSphere   Float?
  vpLeftEyeAxis      Float?
  vpLeftEyeCylinder  Float?
  vpLeftEyePrism     Float?
  vpLeftEyeSphere    Float?
  vpRightEyeAxis     Float?
  vpRightEyeCylinder Float?
  vpRightEyePrism    Float?
  vpRightEyeSphere   Float?
  vpLeftEyeAdd       Float?
  vpRightEyeAdd      Float?
  orders             Order[]
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model LensType {
  id               String   @id @default(cuid())
  name             String
  category         String
  material         String
  index            Float
  baseCost         Float
  sellingPrice     Float
  stock            Int      @default(0)
  reorderThreshold Int      @default(5)
  supplierName     String
  supplierContact  String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders           Order[]
  vlLeftEyeOrders  Order[]  @relation("VLLeftEyeLensType")
  vlRightEyeOrders Order[]  @relation("VLRightEyeLensType")
  vpLeftEyeOrders  Order[]  @relation("VPLeftEyeLensType")
  vpRightEyeOrders Order[]  @relation("VPRightEyeLensType")

  @@index([userId])
}

model LensAddon {
  id             String   @id @default(cuid())
  name           String
  description    String
  additionalCost Float
  sellingPrice   Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]  @relation("LensAddonToOrder")
}

model ContactLens {
  id           String   @id @default(cuid())
  brand        String
  model        String?
  price        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Frame {
  id           String       @id @default(cuid())
  brand        String
  model        String
  color        String
  size         String
  cost         Float
  sellingPrice Float
  stock        Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
  orderFrames  OrderFrame[]

  @@index([userId])
}

model Order {
  id                     String        @id @default(cuid())
  orderNumber            String
  customerId             String
  prescriptionId         String?
  frameId                String?
  lensTypeId             String?
  vlRightEyeLensTypeId   String?
  vlLeftEyeLensTypeId    String?
  vpRightEyeLensTypeId   String?
  vpLeftEyeLensTypeId    String?
  framePrice             Float?
  vlRightEyeLensPrice    Float?
  vlLeftEyeLensPrice     Float?
  vpRightEyeLensPrice    Float?
  vpLeftEyeLensPrice     Float?
  basePrice              Float
  addonsPrice            Float
  totalPrice             Float
  depositAmount          Float
  balanceDue             Float
  status                 String
  expectedCompletionDate DateTime
  actualCompletionDate   DateTime?
  customerNotes          String?
  technicalNotes         String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  userId                 String
  vlLeftEyeLensQuantity  Int           @default(1)
  vlRightEyeLensQuantity Int           @default(1)
  vpLeftEyeLensQuantity  Int           @default(1)
  vpRightEyeLensQuantity Int           @default(1)
  customer               Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  frame                  Frame?        @relation(fields: [frameId], references: [id])
  lensType               LensType?     @relation(fields: [lensTypeId], references: [id])
  prescription           Prescription? @relation(fields: [prescriptionId], references: [id], onDelete: Restrict)
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vlLeftEyeLensType      LensType?     @relation("VLLeftEyeLensType", fields: [vlLeftEyeLensTypeId], references: [id])
  vlRightEyeLensType     LensType?     @relation("VLRightEyeLensType", fields: [vlRightEyeLensTypeId], references: [id])
  vpLeftEyeLensType      LensType?     @relation("VPLeftEyeLensType", fields: [vpLeftEyeLensTypeId], references: [id])
  vpRightEyeLensType     LensType?     @relation("VPRightEyeLensType", fields: [vpRightEyeLensTypeId], references: [id])
  orderFrames            OrderFrame[]
  payments               Payment[]
  addons                 LensAddon[]   @relation("LensAddonToOrder")

  @@unique([orderNumber, userId])
  @@index([orderNumber])
  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([expectedCompletionDate])
  @@index([balanceDue])
  @@index([depositAmount])
}

model OrderFrame {
  id       String @id @default(cuid())
  orderId  String
  frameId  String
  quantity Int    @default(1)
  price    Float
  frame    Frame  @relation(fields: [frameId], references: [id])
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, frameId])
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String?
  amount        Float
  paymentMethod String
  paymentDate   DateTime
  receiptNumber String   @unique
  reference     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  description   String?
  type          String   @default("ORDER")
  userId        String?
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
  @@index([paymentDate])
  @@index([paymentMethod])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String
  date        DateTime
  notes       String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([userId])
  @@index([category])
}

model Setting {
  id              String   @id @default(cuid())
  userId          String?  @unique
  opticianName    String   @default("Optical Shop")
  opticianAddress String   @default("123 Main Street, City, Country")
  opticianPhone   String   @default("+1 234 567 8900")
  opticianEmail   String?
  logoUrl         String?
  language        String   @default("en")
  currency        String   @default("DA")
  timezone        String   @default("Africa/Algiers")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
